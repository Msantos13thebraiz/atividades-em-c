include <stdio.h>
#include <math.h>

int main() {
    float numero;
    
    printf("Digite um número real: ");
    scanf("%f", &numero);
    
    if (numero >= 0) {
        float raiz = sqrt(numero);
        printf("A raiz quadrada de %.2f é %.2f\n", numero, raiz);
    } else {
        float cubo = pow(numero, 3);
        printf("O cubo de %.2f é %.2f\n", numero, cubo);
    }
    
    return 0;
}
