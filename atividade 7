#include <stdio.h>

int main() {
    float lado1, lado2, lado3;
    
    printf("Digite o primeiro lado: ");
    scanf("%f", &lado1);
    printf("Digite o segundo lado: ");
    scanf("%f", &lado2);
    printf("Digite o terceiro lado: ");
    scanf("%f", &lado3);
    
    // Verificar se forma um triângulo
    if ((lado1 + lado2 > lado3) && (lado1 + lado3 > lado2) && (lado2 + lado3 > lado1)) {
        printf("Os lados formam um triângulo!\n");
        
        // Verificar o tipo
        if (lado1 == lado2 && lado2 == lado3) {
            printf("Triângulo EQUILÁTERO (3 lados iguais)\n");
        } else if (lado1 == lado2 || lado1 == lado3 || lado2 == lado3) {
            printf("Triângulo ISÓSCELES (2 lados iguais)\n");
        } else {
            printf("Triângulo ESCALENO (3 lados diferentes)\n");
        }
    } else {
        printf("Não forma um triângulo!\n");
    }
    
    return 0;
}
