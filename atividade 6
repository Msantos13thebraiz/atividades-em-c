#include <stdio.h>

int main() {
    float salario, novo_salario;
    
    printf("Digite o salário atual: R$ ");
    scanf("%f", &salario);
    
    if (salario <= 990.00) {
        novo_salario = salario * 1.20;
        printf("Salário reajustado: R$ %.2f (aumento de 20%%)\n", novo_salario);
    } else if (salario <= 1480.00) {
        novo_salario = salario * 1.10;
        printf("Salário reajustado: R$ %.2f (aumento de 10%%)\n", novo_salario);
    } else if (salario <= 2000.00) {
        novo_salario = salario * 1.05;
        printf("Salário reajustado: R$ %.2f (aumento de 5%%)\n", novo_salario);
    } else {
        printf("Salário atual: R$ %.2f (sem reajuste)\n", salario);
    }
    
    return 0;
}
