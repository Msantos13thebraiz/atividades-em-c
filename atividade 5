#include <stdio.h>

int main() {
    int numero;
    
    printf("Digite um número inteiro: ");
    scanf("%d", &numero);
    
    if (numero > 10 && numero < 100) {
        printf("Número está entre 10 e 100 – intervalo permitido\n");
    } else {
        printf("Número fora do intervalo permitido\n");
    }
    
    return 0;
}
